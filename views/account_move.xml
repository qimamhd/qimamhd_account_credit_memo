<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="hide_credit_memo_from_inv_view" model="ir.ui.view">
        <field name="name">hide_credit_memo_from_inv_view</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
            <field name="arch" type="xml">

                <xpath expr="//field[@name='ref']" position="after">
                    <field name="hide_credit_note_report"
                        attrs="{'invisible': ['|',
                            ('reversed_entry_id', '=', False),
                            ('type', '!=', 'out_refund')]}" groups="qimamhd_account_credit_memo.group_hide_return_complete_invoice_priv"/>
                </xpath>
                <xpath expr="//button[@name='action_reverse']" position="attributes">
                    <attribute name="attrs">{'invisible':[('type','in',['out_refund','in_refund'])]}</attribute>
                </xpath>  

                 <!-- إضافة الحقل -->
                <xpath expr="//sheet//group" position="inside">
                    <field name="use_report_attachment"/>
                </xpath>

                <!-- الأزرار -->
                <xpath expr="//header" position="inside">

                    <!-- تفعيل -->
                    <button name="action_toggle_attachment"
                            type="object"
                            string="تفعيل المرفق"
                            class="btn-success"
                            attrs="{'invisible': [('use_report_attachment','=',True)]}"/>

                    <!-- تعطيل -->
                    <button name="action_toggle_attachment"
                            type="object"
                            string="إلغاء المرفق"
                            class="btn-danger"
                            attrs="{'invisible': [('use_report_attachment','=',False)]}"/>

                </xpath>

           </field>
    </record>
         
</odoo>
