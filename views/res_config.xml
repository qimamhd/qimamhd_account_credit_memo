<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="res_config_settings_view_attachment" model="ir.ui.view">
        <field name="name">res.config.settings.attachment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[hasclass('settings')]" position="inside">

                <div class="app_settings_block" string="Invoice Attachment">
                    <h2>Invoice Attachment</h2>

                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">

                            <div class="o_setting_left_pane">
                                <field name="use_global_report_attachment"/>
                            </div>

                            <div class="o_setting_right_pane">
                                <label for="use_global_report_attachment"/>
                                <div class="text-muted">
                                    Enable automatic PDF attachment for all posted invoices.
                                </div>
                            </div>

                        </div>
                    </div>

                </div>

            </xpath>

        </field>
    </record>

</odoo>